// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserAuth {
  id              Int             @id @default(autoincrement())
  email_id        String          @unique
  password        String
  institution_id  Int?
  institution     Institute?      @relation(fields: [institution_id], references: [id], onDelete: Cascade)
  department_id   Int?
  department      Department?     @relation(fields: [department_id], references: [id], onDelete: Cascade)
  role            String
  is_active       Boolean         @default(true)
  events          EventsBooking[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Institute {
  id              Int          @id @default(autoincrement())
  institute_name  String
  departments     Department[]
  userAuths       UserAuth[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Department {
  id              Int          @id @default(autoincrement())
  department_name String
  instituteId     Int
  institute       Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  userAuths       UserAuth[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model EventsBooking {
  id                          Int       @id @default(autoincrement())

  event_applicant_name        String
  event_applicant_institution String
  event_department            String
  event_designation           String
  event_organizer_name        String
  event_organizer_phone       String
  event_details               String
  event_purpose               String

  event_date                  DateTime
  event_start_time            DateTime
  event_end_time              DateTime

  event_participant_count     Int

  event_guest_name            String
  event_presiding_officers    Int

  event_micset                Boolean   @default(false)
  event_white_board           Boolean   @default(false)

  approvals                   Json?
  officeUse                   Json?

  userId                      Int?
  user                        UserAuth? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
}


model TemplateBlobUrl{
  id                          Int      @id @default(autoincrement())
  template_blob_url_name String
  template_file    String
  template_blob_url    String
  template_blob_url_epires_duriation Int
  template_url_status String
  template_password String
  template_comment String?
  template_activated_count Int @default(1)
  firstViewedAt               DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}